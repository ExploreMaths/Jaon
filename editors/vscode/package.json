{
  "name": "jaon-lang",
  "displayName": "Jaon Language Support",
  "description": "Syntax highlighting and run button for the Jaon programming language.",
  "version": "0.0.7",
  "publisher": "exploremaths",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ExploreMaths/Jaon.git"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages",
    "Debuggers"
  ],
  "keywords": [
    "jaon",
    "language",
    "programming language"
  ],
  "activationEvents": [
    "onLanguage:jaon"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "jaon",
        "aliases": [
          "Jaon"
        ],
        "extensions": [
          ".jaon"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./images/file-icon.svg",
          "dark": "./images/file-icon.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "jaon",
        "scopeName": "source.jaon",
        "path": "./syntaxes/jaon.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "jaon.run",
        "title": "Run Jaon File",
        "icon": "$(play)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "when": "resourceExtname == .jaon",
          "command": "jaon.run",
          "group": "navigation@1"
        }
      ],
      "commandPalette": [
        {
          "command": "jaon.run",
          "when": "editorLangId == jaon"
        }
      ]
    },
    "configuration": {
      "title": "Jaon",
      "properties": {
        "jaon.executablePath": {
          "type": "string",
          "default": "jaon",
          "description": "Path to the Jaon executable. Use 'jaon' if it is on PATH, or an absolute path to compiler.exe."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/node": "20.x",
    "typescript": "^5.4.0"
  }
}
