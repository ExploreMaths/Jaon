{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Jaon",
  "scopeName": "source.jaon",
  "fileTypes": [
    ".jaon"
  ],
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#function-definitions"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#types"
    },
    {
      "include": "#constants"
    },
    {
      "include": "#builtin-functions"
    },
    {
      "include": "#functions"
    },
    {
      "include": "#identifiers"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#punctuation"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.jaon",
          "match": "//.*$"
        },
        {
          "name": "comment.block.jaon",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.jaon",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.jaon",
              "match": "\\\\(n|t|r|\\\\|\"|')"
            }
          ]
        },
        {
          "name": "string.quoted.single.jaon",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.jaon",
              "match": "\\\\(n|t|r|\\\\|\"|')"
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.jaon",
          "match": "\\b\\d+\\.\\d+\\b"
        },
        {
          "name": "constant.numeric.integer.jaon",
          "match": "\\b\\d+\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.jaon",
          "match": "\\b(if|elif|else|while|for|in|break|continue|return|try|catch|finally|throw|import)\\b"
        },
        {
          "name": "keyword.declaration.jaon",
          "match": "\\b(var|val|fun|class|extends|constructor|new|this)\\b"
        },
        {
          "name": "keyword.access.jaon",
          "match": "\\b(public|private|static)\\b"
        },
        {
          "name": "keyword.operator.logical.jaon",
          "match": "\\b(and|or|not)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.primitive.jaon",
          "match": "\\b(Int|Float|Bool|String|List|Dict|Any)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.jaon",
          "match": "\\b(true|false|null)\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.jaon",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()"
        }
      ]
    },
    "builtin-functions": {
      "patterns": [
        {
          "name": "support.function.builtin.jaon",
          "match": "\\b(print|println|input|len|range|str|int|float|type)\\b"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.readwrite.jaon",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
        }
      ]
    },
    "function-definitions": {
      "patterns": [
        {
          "match": "\\b(fun)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": {
              "name": "keyword.declaration.jaon"
            },
            "2": {
              "name": "entity.name.function.jaon"
            }
          }
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.jaon",
          "match": "(==|!=|<=|>=|<|>)"
        },
        {
          "name": "keyword.operator.assignment.jaon",
          "match": "(=)"
        },
        {
          "name": "keyword.operator.arithmetic.jaon",
          "match": "(\\+|-\\+|\\*|/|%)"
        },
        {
          "name": "keyword.operator.arrow.jaon",
          "match": "(->)"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.terminator.jaon",
          "match": "(;)"
        },
        {
          "name": "punctuation.separator.comma.jaon",
          "match": "(,|:)"
        },
        {
          "name": "punctuation.accessor.jaon",
          "match": "(\\.)"
        }
      ]
    }
  }
}
