{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Helios",
  "scopeName": "source.helios",
  "fileTypes": [
    ".helios"
  ],
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#types"
    },
    {
      "include": "#constants"
    },
    {
      "include": "#functions"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#punctuation"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.helios",
          "match": "//.*$"
        },
        {
          "name": "comment.block.helios",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.helios",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.helios",
              "match": "\\\\(n|t|r|\\\\|\"|')"
            }
          ]
        },
        {
          "name": "string.quoted.single.helios",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.helios",
              "match": "\\\\(n|t|r|\\\\|\"|')"
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.helios",
          "match": "\\b\\d+\\.\\d+\\b"
        },
        {
          "name": "constant.numeric.integer.helios",
          "match": "\\b\\d+\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.helios",
          "match": "\\b(if|elif|else|while|for|in|break|continue|return|try|catch|finally|throw|import)\\b"
        },
        {
          "name": "keyword.declaration.helios",
          "match": "\\b(var|val|fun|class|extends|constructor|new|this)\\b"
        },
        {
          "name": "keyword.access.helios",
          "match": "\\b(public|private|static)\\b"
        },
        {
          "name": "keyword.operator.logical.helios",
          "match": "\\b(and|or|not)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.primitive.helios",
          "match": "\\b(Int|Float|Bool|String|List|Dict|Any)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.helios",
          "match": "\\b(true|false|null)\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.helios",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.helios",
          "match": "(==|!=|<=|>=|<|>)"
        },
        {
          "name": "keyword.operator.assignment.helios",
          "match": "(=)"
        },
        {
          "name": "keyword.operator.arithmetic.helios",
          "match": "(\\+|-\\+|\\*|/|%)"
        },
        {
          "name": "keyword.operator.arrow.helios",
          "match": "(->)"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.terminator.helios",
          "match": "(;)"
        },
        {
          "name": "punctuation.separator.comma.helios",
          "match": "(,|:)"
        },
        {
          "name": "punctuation.accessor.helios",
          "match": "(\\.)"
        }
      ]
    }
  }
}
