// Fibonacci sequence
fun fib(n: Int): Int {
    if (n <= 1) {
        return n;
    }
    return fib(n - 1) + fib(n - 2);
}

for (i in range(10)) {
    print(fib(i));
    print(" ");
}
println("");

// Iterative version
fun fib_iter(n: Int): Int {
    if (n <= 1) {
        return n;
    }
    var a: Int = 0;
    var b: Int = 1;
    var i = 2;
    while (i <= n) {
        var temp = a + b;
        a = b;
        b = temp;
        i = i + 1;
    }
    return b;
}

println(fib_iter(20));
